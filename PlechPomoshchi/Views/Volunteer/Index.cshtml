@model VolunteerOrgApplicationVm
@{
    ViewData["Title"] = "Для волонтёров";
}
<div class="container-fluid px-3 px-lg-4 py-5">
    <h1 class="pp-h1">Для волонтёров</h1>
    <p class="text-muted">Если вашей организации нет в мониторинге — отправьте заявку.</p>

    @if (TempData["ok"] != null)
    {
        <div class="alert alert-success">@TempData["ok"]</div>
    }

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label">Название организации</label>
                            <input class="form-control" asp-for="OrgName" />
                            <span class="text-danger small" asp-validation-for="OrgName"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Сайт (необязательно)</label>
                            <input class="form-control" asp-for="Website" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Контактное лицо</label>
                            <input class="form-control" asp-for="ContactName" />
                            <span class="text-danger small" asp-validation-for="ContactName"></span>
                        </div>

                        <div class="row g-2">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Email</label>
                                <input class="form-control" asp-for="ContactEmail" />
                                <span class="text-danger small" asp-validation-for="ContactEmail"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Телефон (опционально)</label>
                                <input class="form-control" asp-for="ContactPhone" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Сообщение</label>
                            <textarea class="form-control" asp-for="Message" rows="5"></textarea>
                            <span class="text-danger small" asp-validation-for="Message"></span>
                        </div>

                        <button class="btn btn-primary btn-lg" type="submit">Подать заявку</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="pp-volphoto">
                    <img id="volPhotoPage" src="/img/vol/v2.svg" alt="Волонтёры" />
                </div>
                <div class="card-body">
                    <div class="fw-semibold">Фото волонтёров</div>
                    <div class="small text-muted">Заглушки можно заменить на реальные.</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/volunteer.js" asp-append-version="true"></script>
}
