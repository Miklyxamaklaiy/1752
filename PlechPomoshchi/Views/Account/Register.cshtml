@model RegisterVm
@{
    ViewData["Title"] = "Регистрация";
}
<div class="container-fluid px-3 px-lg-4 py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">
            <h1 class="pp-h1 mb-3">Регистрация</h1>
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label">ФИО</label>
                            <input class="form-control" asp-for="FullName" />
                            <span class="text-danger small" asp-validation-for="FullName"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input class="form-control" asp-for="Email" />
                            <span class="text-danger small" asp-validation-for="Email"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Телефон (опционально)</label>
                            <input class="form-control" asp-for="Phone" />
                        </div>

                        <div class="row g-2">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Пароль</label>
                                <input class="form-control" asp-for="Password" type="password" />
                                <span class="text-danger small" asp-validation-for="Password"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Подтверждение</label>
                                <input class="form-control" asp-for="ConfirmPassword" type="password" />
                                <span class="text-danger small" asp-validation-for="ConfirmPassword"></span>
                            </div>
                        </div>

                        <button class="btn btn-primary w-100" type="submit">Создать аккаунт</button>
                    </form>

                    <div class="mt-3 small text-muted">
                        Уже есть аккаунт? <a href="/Account/Login">Войти</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
