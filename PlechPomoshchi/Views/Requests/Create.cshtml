@model CreateRequestVm
@{
    ViewData["Title"] = "Создать заявку";
    var categories = new[] { "Материальная", "Юридическая", "Медицинская", "Психологическая", "Другая" };
}
<div class="container-fluid px-3 px-lg-4 py-5">
    <h1 class="pp-h1">Создать заявку</h1>
    <p class="text-muted">Роль “Заявитель” может создавать заявки и видеть только свои.</p>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Категория</label>
                    <select class="form-select" asp-for="Category">
                        @foreach (var c in categories)
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Описание</label>
                    <textarea class="form-control" asp-for="Description" rows="6"></textarea>
                    <span class="text-danger small" asp-validation-for="Description"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Файл (опционально)</label>
                    <input type="file" name="file" class="form-control" />
                    <div class="small text-muted mt-1">Максимум 10 МБ.</div>
                </div>

                <button class="btn btn-primary btn-lg" type="submit">Отправить</button>
                <a class="btn btn-outline-secondary btn-lg" href="/Requests/My">Отмена</a>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
