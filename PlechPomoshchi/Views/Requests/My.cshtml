@model List<HelpRequest>
@{
    ViewData["Title"] = "Мои заявки";
}
<div class="container-fluid px-3 px-lg-4 py-5">
    <div class="d-flex align-items-end justify-content-between gap-3">
        <div>
            <h1 class="pp-h1 mb-1">Мои заявки</h1>
            <div class="text-muted">Заявки видит только автор (роль “Заявитель”).</div>
        </div>
        <a class="btn btn-primary" href="/Requests/Create">Создать заявку</a>
    </div>

    <div class="card border-0 shadow-sm mt-4">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Категория</th>
                        <th>Статус</th>
                        <th>Дата</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>@r.Category</td>
                        <td><span class="badge bg-secondary">@r.Status</span></td>
                        <td>@r.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" href="/Requests/Details/@r.Id">Открыть</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
